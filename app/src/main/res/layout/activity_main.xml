<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#1a1a2e">

    <!-- ==================== 左侧：一级目录（分类）===================== -->
    <LinearLayout
        android:id="@+id/panelCategory"
        android:layout_width="180dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#804D6B9B">

        <!-- 源切换区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="6dp"
            android:background="#803D5A8A">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="直播源"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSourceVip"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="VIP"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginRight="2dp"
                    android:background="#FF6A8CBF"
                    android:onClick="switchSource" />

                <Button
                    android:id="@+id/btnSourceBaohes"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="宝盒"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginRight="2dp"
                    android:background="#FF6A8CBF"
                    android:onClick="switchSource" />

                <Button
                    android:id="@+id/btnSourceAi"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="AI"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginRight="2dp"
                    android:background="#FF6A8CBF"
                    android:onClick="switchSource" />

                <Button
                    android:id="@+id/btnScanQr"
                    android:layout_width="0dp"
                    android:layout_height="28dp"
                    android:layout_weight="1"
                    android:text="扫码"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="#FF6A8CBF"
                    android:onClick="scanQRCode" />
            </LinearLayout>
        </LinearLayout>

        <!-- 一级目录标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▼ 分类"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:padding="6dp"
            android:background="#803D5A8A" />

        <!-- 分类列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/categoryList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="4dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- ==================== 中间：二级目录（频道）===================== -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#804D6B9B">

        <!-- 二级目录标题 -->
        <TextView
            android:id="@+id/tvCategoryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请选择分类"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:padding="8dp"
            android:background="#803D5A8A"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- 频道列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/channelList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="4dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- ==================== 右侧：播放器 + 三级目录 ===================== -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2.2"
        android:orientation="vertical"
        android:background="#804D6B9B">

        <!-- 播放器 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.media3.ui.PlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:show_buffering="when_playing"
                app:use_controller="false" />

            <ProgressBar
                android:id="@+id/loading"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvNoSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="暂无频道"
                android:textColor="#AAAAAA"
                android:textSize="16sp" />

        </FrameLayout>

        <!-- 三级目录标题 -->
        <TextView
            android:id="@+id/tvSourceTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="请选择频道"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:padding="8dp"
            android:background="#803D5A8A"
            android:singleLine="true"
            android:ellipsize="end" />

        <!-- 源列表（横向） -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/sourceList"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:background="#803D5A8A"
            android:padding="4dp"
            android:clipToPadding="false" />

    </LinearLayout>

</LinearLayout>
